{
  "// schema": "Each entry binds a key + modifier combination to an Action enum value (see keybindings.odin). Modifier names: Ctrl, Shift, Alt (= Option), Gui (= Cmd on macOS). Key names: letters A-Z, digits 0-9, F1-F24, or one of Space/Tab/Return/Escape/Backspace/Delete/Left/Right/Up/Down/Home/End/PageUp/PageDown. Renaming an Action is a breaking change for this file.",
  "// note": "Defaults match Windows/Linux for portability — change \"Ctrl\" to \"Gui\" on any entry below to use Cmd instead.",

  "bindings": [
    { "key": "Q",   "modifiers": ["Ctrl"],            "action": "Quit" },

    { "key": "F1",  "modifiers": [],                  "action": "Help" },
    { "key": "F2",  "modifiers": [],                  "action": "FileBrowser" },
    { "key": "F3",  "modifiers": [],                  "action": "GitHistory" },
    { "key": "F4",  "modifiers": [],                  "action": "OpenDocs" },
    { "key": "F5",  "modifiers": [],                  "action": "MarkdownPreview" },
    { "key": "F6",  "modifiers": [],                  "action": "Symbols" },
    { "key": "F7",  "modifiers": [],                  "action": "Tasks" },
    { "key": "F7",  "modifiers": ["Shift"],           "action": "ToggleDebugPanel" },
    { "key": "F8",  "modifiers": [],                  "action": "ToggleDiff" },
    { "key": "F9",  "modifiers": [],                  "action": "ToggleTerminal" },
    { "key": "F9",  "modifiers": ["Gui"],            "action": "NewTerminal" },
    { "key": "F9",  "modifiers": ["Gui","Shift"],    "action": "PickTerminal" },
    { "key": "F10", "modifiers": [],                  "action": "StepOver" },
    { "key": "F11", "modifiers": [],                  "action": "StepIn" },

    { "key": "S",   "modifiers": ["Gui"],            "action": "SaveFile" },
    { "key": "S",   "modifiers": ["Gui","Shift"],    "action": "SaveFileAs" },
    { "key": "F4",  "modifiers": ["Gui"],            "action": "CloseFile" },

    { "key": "F",   "modifiers": ["Gui"],            "action": "FindToggle" },
    { "key": "F",   "modifiers": ["Gui","Shift"],    "action": "FindInFiles" },
    { "key": "R",   "modifiers": ["Gui"],            "action": "ReplaceToggle" },
    { "key": "R",   "modifiers": ["Gui","Shift"],    "action": "ReplaceInFiles" },

    { "key": "Tab",   "modifiers": ["Ctrl"],          "action": "SwapPanes" },
    { "key": "Left",  "modifiers": ["Gui"],          "action": "FocusLeftPane" },
    { "key": "Right", "modifiers": ["Gui"],          "action": "FocusRightPane" },
    { "key": "Left",  "modifiers": ["Gui","Shift"],  "action": "MoveToLeftPane" },
    { "key": "Right", "modifiers": ["Gui","Shift"],  "action": "MoveToRightPane" },
    { "key": "W",   "modifiers": ["Gui"],            "action": "ToggleWrap" },

    { "key": "K",     "modifiers": ["Gui"],          "action": "Hover" },
    { "key": "Space", "modifiers": ["Ctrl"],          "action": "TriggerCompletion" },

    { "key": "Z",   "modifiers": ["Gui"],            "action": "Undo" },
    { "key": "Z",   "modifiers": ["Gui","Shift"],    "action": "Redo" },
    { "key": "Y",   "modifiers": ["Gui"],            "action": "Redo" },
    { "key": "A",   "modifiers": ["Gui"],            "action": "SelectAll" },
    { "key": "C",   "modifiers": ["Gui"],            "action": "Copy" },
    { "key": "V",   "modifiers": ["Gui"],            "action": "Paste" },

    { "key": "C",   "modifiers": ["Gui","Shift"],    "action": "TerminalCopy" },
    { "key": "V",   "modifiers": ["Gui","Shift"],    "action": "TerminalPaste" },

    { "key": "R",   "modifiers": ["Gui"],            "action": "BrowseRename" },
    { "key": "N",   "modifiers": ["Gui"],            "action": "BrowseNewFile" },
    { "key": "Z",   "modifiers": ["Gui"],            "action": "BrowseUndo" },
    { "key": "P",   "modifiers": ["Gui"],            "action": "BrowseSetProjectRoot" }
  ]
}
