  "symbol_patterns": [
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Static} Sub {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Static} Function {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} Property Get {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} Property Let {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} Property Set {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} Event {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} Declare Sub {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} Declare Function {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:PtrSafe} Declare Sub {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:PtrSafe} Declare Function {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} Type {NAME}",
      "kind": "Type"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} Enum {NAME}",
      "kind": "Type"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Global} Const {NAME}",
      "kind": "Variable"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Global} {OPTIONAL:Static} Dim {NAME}",
      "kind": "Variable"
    }
