{
  "name": "JavaScript",
  "extensions": ["js", "mjs", "cjs", "jsx"],
  "line_comment": "//",
  "block_comment_start": "/*",
  "block_comment_end": "*/",
  "preprocessor_prefix": "",
  "keywords": [
    "var", "let", "const", "function", "return",
    "if", "else", "for", "while", "do", "switch", "case", "default", "break", "continue",
    "in", "of", "typeof", "instanceof", "delete", "void",
    "new", "this", "super", "class", "extends",
    "throw", "try", "catch", "finally",
    "async", "await", "yield",
    "import", "export", "from", "as",
    "static", "get", "set",
    "debugger", "with"
  ],
  "types": [
    "true", "false", "null", "undefined",
    "NaN", "Infinity",
    "Array", "Object", "String", "Number", "Boolean", "Date", "RegExp", "Map", "Set", "Promise",
    "Symbol", "BigInt", "Error", "Function", "Math", "JSON"
  ]
}
