  "scope_start": [
    "SUB",
    "FUNCTION",
    "TYPE"
  ],
  "scope_end": [
    "END"
  ],
  "symbol_patterns": [
    {
      "pattern": "{NOTHING} SUB {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} FUNCTION {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} DECLARE SUB {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} DECLARE FUNCTION {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} DEF {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} TYPE {NAME}",
      "kind": "Type"
    },
    {
      "pattern": "{NOTHING} CONST {NAME}",
      "kind": "Variable"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:STATIC} DIM {NAME}",
      "kind": "Variable"
    },
    {
      "pattern": "{NOTHING} SHARED {NAME}",
      "kind": "Variable"
    },
    {
      "pattern": "{NOTHING} COMMON {NAME}",
      "kind": "Variable"
    }
  ]
}