    "Module",
    "Namespace",
    "Structure",
    "Interface",
    "Enum",
    "Property"
  ],
  "scope_end": [
    "End"
  ],
  "symbol_patterns": [
    {
      "pattern": "{NOTHING} Namespace {NAME}",
      "kind": "Module"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} Module {NAME}",
      "kind": "Type"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} {OPTIONAL:Partial} {OPTIONAL:MustInherit} {OPTIONAL:NotInheritable} Class {NAME}",
      "kind": "Type"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} {OPTIONAL:Partial} Structure {NAME}",
      "kind": "Type"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} Interface {NAME}",
      "kind": "Type"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} Enum {NAME}",
      "kind": "Type"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} {OPTIONAL:Shared} {OPTIONAL:Overridable} {OPTIONAL:Overrides} {OPTIONAL:MustOverride} {OPTIONAL:Partial} {OPTIONAL:Async} {OPTIONAL:Iterator} Sub {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} {OPTIONAL:Shared} {OPTIONAL:Overridable} {OPTIONAL:Overrides} {OPTIONAL:MustOverride} {OPTIONAL:Partial} {OPTIONAL:Async} {OPTIONAL:Iterator} Function {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} {OPTIONAL:Shared} {OPTIONAL:ReadOnly} {OPTIONAL:WriteOnly} {OPTIONAL:Overridable} {OPTIONAL:Overrides} {OPTIONAL:Default} Property {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} Event {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} Delegate {OPTIONAL:Sub} {OPTIONAL:Function} {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} {OPTIONAL:Shared} Operator {NAME}",
      "kind": "Function"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} {OPTIONAL:Shared} Const {NAME}",
      "kind": "Variable"
    },
    {
      "pattern": "{NOTHING} {OPTIONAL:Public} {OPTIONAL:Private} {OPTIONAL:Friend} {OPTIONAL:Protected} {OPTIONAL:Shared} {OPTIONAL:ReadOnly} Dim {NAME}",
      "kind": "Variable"
    }
  ]
}