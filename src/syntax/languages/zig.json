{
  "name": "Zig",
  "extensions": [
    "zig",
    "zon"
  ],
  "line_comment": "//",
  "block_comment_start": "",
  "block_comment_end": "",
  "preprocessor_prefix": "",
  "keywords": [
    "const",
    "var",
    "fn",
    "return",
    "pub",
    "export",
    "extern",
    "packed",
    "align",
    "linksection",
    "callconv",
    "threadlocal",
    "allowzero",
    "volatile",
    "if",
    "else",
    "switch",
    "while",
    "for",
    "break",
    "continue",
    "struct",
    "enum",
    "union",
    "error",
    "opaque",
    "defer",
    "errdefer",
    "try",
    "catch",
    "orelse",
    "comptime",
    "inline",
    "noinline",
    "async",
    "await",
    "suspend",
    "resume",
    "nosuspend",
    "anyframe",
    "test",
    "usingnamespace",
    "asm",
    "unreachable",
    "and",
    "or",
    "true",
    "false",
    "null",
    "undefined"
  ],
  "types": [
    "i8",
    "i16",
    "i32",
    "i64",
    "i128",
    "isize",
    "u8",
    "u16",
    "u32",
    "u64",
    "u128",
    "usize",
    "f16",
    "f32",
    "f64",
    "f80",
    "f128",
    "bool",
    "void",
    "type",
    "anyerror",
    "anyopaque",
    "noreturn",
    "anytype",
    "comptime_int",
    "comptime_float",
    "c_char",
    "c_short",
    "c_ushort",
    "c_int",
    "c_uint",
    "c_long",
    "c_ulong",
    "c_longlong",
    "c_ulonglong",
    "c_longdouble"
  ],
  "symbol_patterns": [
    {
      "pattern": "fn NAME",
      "kind": "Function"
    },
    {
      "pattern": "pub fn NAME",
      "kind": "Function"
    },
    {
      "pattern": "const NAME =",
      "kind": "Variable"
    },
    {
      "pattern": "pub const NAME =",
      "kind": "Variable"
    },
    {
      "pattern": "var NAME =",
      "kind": "Variable"
    },
    {
      "pattern": "pub var NAME =",
      "kind": "Variable"
    }
  ]
}