{
  "name": "Ruby",
  "extensions": [
    "rb",
    "ruby",
    "rake",
    "gemspec"
  ],
  "line_comment": "#",
  "block_comment_start": "",
  "block_comment_end": "",
  "preprocessor_prefix": "",
  "keywords": [
    "alias",
    "and",
    "begin",
    "break",
    "case",
    "class",
    "def",
    "defined?",
    "do",
    "else",
    "elsif",
    "end",
    "ensure",
    "for",
    "if",
    "in",
    "module",
    "next",
    "not",
    "or",
    "redo",
    "rescue",
    "retry",
    "return",
    "self",
    "super",
    "then",
    "undef",
    "unless",
    "until",
    "when",
    "while",
    "yield",
    "BEGIN",
    "END",
    "require",
    "require_relative",
    "load",
    "include",
    "extend",
    "attr_accessor",
    "attr_reader",
    "attr_writer",
    "lambda",
    "proc",
    "raise",
    "throw",
    "catch",
    "private",
    "protected",
    "public"
  ],
  "types": [
    "true",
    "false",
    "nil",
    "String",
    "Symbol",
    "Integer",
    "Float",
    "Numeric",
    "Range",
    "Array",
    "Hash",
    "Set",
    "Struct",
    "Object",
    "Class",
    "Module",
    "Proc",
    "Method",
    "Exception",
    "StandardError",
    "RuntimeError",
    "ArgumentError",
    "TypeError",
    "IO",
    "File",
    "Dir"
  ],
  "symbol_patterns": [
    {
      "pattern": "def NAME",
      "kind": "Function"
    },
    {
      "pattern": "class NAME",
      "kind": "Type"
    },
    {
      "pattern": "module NAME",
      "kind": "Module"
    }
  ]
}