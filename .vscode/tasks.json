{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build: Windows (debug)",
			"type": "shell",
			"windows": {
				"command": "powershell",
				"args": [
					"-NoProfile",
					"-ExecutionPolicy", "Bypass",
					"-File", "scripts/build.ps1",
					"-Target", "windows",
					"-Config", "debug"
				]
			},
			"linux": {
				"command": "bash",
				"args": ["scripts/build.sh", "windows", "debug"]
			},
			"osx": {
				"command": "bash",
				"args": ["scripts/build.sh", "windows", "debug"]
			},
			"options": { "cwd": "${workspaceFolder}" },
			"group": { "kind": "build", "isDefault": true },
			"problemMatcher": [
				{
					"owner": "odin",
					"fileLocation": ["relative", "${workspaceFolder}"],
					"pattern": {
						"regexp": "^(.*?)\\((\\d+):(\\d+)\\)\\s+(Error|Warning|Syntax Error):\\s+(.*)$",
						"file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
					}
				}
			]
		},
		{
			"label": "Build: Windows (release)",
			"type": "shell",
			"windows": {
				"command": "powershell",
				"args": [
					"-NoProfile",
					"-ExecutionPolicy", "Bypass",
					"-File", "scripts/build.ps1",
					"-Target", "windows",
					"-Config", "release"
				]
			},
			"linux": {
				"command": "bash",
				"args": ["scripts/build.sh", "windows", "release"]
			},
			"osx": {
				"command": "bash",
				"args": ["scripts/build.sh", "windows", "release"]
			},
			"options": { "cwd": "${workspaceFolder}" },
			"group": "build",
			"problemMatcher": [
				{
					"owner": "odin",
					"fileLocation": ["relative", "${workspaceFolder}"],
					"pattern": {
						"regexp": "^(.*?)\\((\\d+):(\\d+)\\)\\s+(Error|Warning|Syntax Error):\\s+(.*)$",
						"file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
					}
				}
			]
		},
