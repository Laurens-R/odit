{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "odin: build (debug)",
			"type": "process",
			"command": "odin",
			"args": [
				"build",
				"src",
				"-subsystem:windows",
				"-debug",
				"-out:odit.exe"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				{
					"owner": "odin",
					"fileLocation": [
						"relative",
						"${workspaceFolder}"
					],
					"pattern": {
						"regexp": "^(.*?)\\((\\d+):(\\d+)\\)\\s+(Error|Warning|Syntax Error):\\s+(.*)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"severity": 4,
						"message": 5
					}
				}
			]
		},
		{
			"label": "odin: run",
			"type": "process",
			"command": "odin",
			"args": [
				"run",
				"src",
				"-debug",
				"-out:odit.exe"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		}
	]
}
