		{
			"label": "Run: Windows (debug)",
			"type": "shell",
			"windows": {
				"command": "${workspaceFolder}\\out\\windows\\debug\\odit.exe"
			},
			"linux": {
				"command": "${workspaceFolder}/out/windows/debug/odit.exe"
			},
			"osx": {
				"command": "${workspaceFolder}/out/windows/debug/odit.exe"
			},
			"options": { "cwd": "${workspaceFolder}/out/windows/debug" },
			"dependsOn": ["Build: Windows (debug)"],
			"problemMatcher": []
		},
		{
			"label": "Run: Windows (release)",
			"type": "shell",
			"windows": {
				"command": "${workspaceFolder}\\out\\windows\\release\\odit.exe"
